<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — NGO Admin</title>
  <style>
    body { font-family: 'Inter', -apple-system, sans-serif; background: #f4f6f9; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
    .error-card { background: #fff; border-radius: 16px; padding: 48px 40px; max-width: 420px; text-align: center; box-shadow: 0 8px 40px rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.06); }
    .error-code { font-size: 64px; font-weight: 800; color: #b8860b; line-height: 1; margin-bottom: 8px; }
    h1 { font-size: 20px; font-weight: 700; color: #111318; margin-bottom: 10px; }
    p { color: #8b93a7; font-size: 14px; margin-bottom: 24px; }
    a { display: inline-flex; padding: 10px 20px; background: #b8860b; color: #fff; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; }
    a:hover { background: #9a7209; }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-code"><%= statusCode || 500 %></div>
    <h1><%= pageTitle || 'Error' %></h1>
    <p><%= message || 'Something went wrong.' %></p>
    <a href="/2ef65f179f12439e317a23628b016653">← Back to Dashboard</a>
  </div>
</body>
</html>
