<%- include('../layout-start', { pageTitle, headExtra, headerActions, breadcrumb }) %>

<div class="card mb-3">
  <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
    <strong><%= monthName %> <%= year %></strong>
    <div style="display:flex;gap:8px;align-items:center;">
      <span class="text-muted fs-12"><%= activityCountInView %> event<%= activityCountInView !== 1 ? 's' : '' %> this month</span>
      <a href="/2ef65f179f12439e317a23628b016653/calendar?year=<%= prevYear %>&month=<%= prevMonth %>" class="btn btn-outline-secondary btn-sm">‹ Prev</a>
      <a href="/2ef65f179f12439e317a23628b016653/calendar" class="btn btn-outline-secondary btn-sm">Today</a>
      <a href="/2ef65f179f12439e317a23628b016653/calendar?year=<%= nextYear %>&month=<%= nextMonth %>" class="btn btn-outline-secondary btn-sm">Next ›</a>
    </div>
  </div>
  <div class="card-body" style="padding:0;">
    <div style="display:grid;grid-template-columns:repeat(7,1fr);border-bottom:1px solid var(--border);">
      <% ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].forEach(function(d) { %>
      <div style="padding:8px 10px;font-size:10.5px;font-weight:650;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-3);text-align:center;background:var(--surface-2);"><%= d %></div>
      <% }); %>
    </div>
    <div style="display:grid;grid-template-columns:repeat(7,1fr);">
      <% var ymdOf = function(d) { return d.date.getFullYear() + '-' + String(d.date.getMonth()+1).padStart(2,'0') + '-' + String(d.date.getDate()).padStart(2,'0'); }; %>
      <% days.forEach(function(d) { %>
      <a href="/2ef65f179f12439e317a23628b016653/calendar?year=<%= year %>&month=<%= month %>&day=<%= ymdOf(d) %>"
         style="min-height:84px;padding:8px;border-right:1px solid var(--border-light);border-bottom:1px solid var(--border-light);text-decoration:none;display:flex;flex-direction:column;gap:4px;
                <%= d.isCurrentMonth ? '' : 'opacity:0.35;' %>
                <%= selectedDay === ymdOf(d) ? 'background:var(--gold-soft);' : '' %>">
        <span style="font-size:12px;font-weight:<%= d.isToday ? '800' : '550' %>;color:<%= d.isToday ? 'var(--gold)' : 'var(--text)' %>;">
          <%= d.day %><% if (d.isToday) { %> <span class="badge badge-gold" style="font-size:8.5px;padding:1px 5px;">Today</span><% } %>
        </span>
        <% if (d.logs.length) { %>
        <span class="badge badge-info" style="font-size:10px;align-self:flex-start;"><%= d.logs.length %> event<%= d.logs.length !== 1 ? 's' : '' %></span>
        <% } %>
      </a>
      <% }); %>
    </div>
  </div>
</div>

<% if (selectedDay) { %>
<div class="card">
  <div class="card-header"><strong>Activity on <%= selectedDay %></strong></div>
  <% if (selectedDayLogs.length === 0) { %>
  <div class="empty-state">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    <p>No activity recorded on this day.</p>
  </div>
  <% } else { %>
  <div class="card-body" style="padding:8px 20px;">
    <% selectedDayLogs.forEach(function(l) { %>
    <div class="activity-item">
      <div>
        <span class="activity-action"><%= l.action %></span>
        <% if (l.details) { %> — <span class="activity-details"><%= l.details %></span><% } %>
        <br><span class="activity-user"><%= l.user %></span>
      </div>
      <span class="activity-time"><%= new Date(l.timestamp).toLocaleTimeString() %></span>
    </div>
    <% }); %>
  </div>
  <% } %>
</div>
<% } %>

<%- include('../layout-end') %>
