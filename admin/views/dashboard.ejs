<%- include('layout-start', { pageTitle, headExtra, headerActions, breadcrumb }) %>

<!-- Welcome banner -->
<div class="welcome-banner">
  <div>
    <h2 class="welcome-title">Welcome, <%= username %> 👋</h2>
    <p class="welcome-date"><%= new Date().toLocaleDateString('en-US', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></p>
  </div>
  <div class="welcome-summary">
    <span><strong><%= stats.totalPages %></strong><span style="font-size:11px;opacity:0.8;margin-top:2px;">Pages</span></span>
    <span><strong><%= stats.updatedPages %></strong><span style="font-size:11px;opacity:0.8;margin-top:2px;">Updated</span></span>
    <span><strong><%= stats.totalMedia %></strong><span style="font-size:11px;opacity:0.8;margin-top:2px;">Media</span></span>
  </div>
</div>

<!-- Stats cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="stat-card stat-card-gold">
      <div class="stat-icon stat-icon-gold">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
      </div>
      <div class="stat-value"><%= stats.totalPages %></div>
      <div class="stat-label">Total Pages</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card stat-card-green">
      <div class="stat-icon stat-icon-green">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
      <div class="stat-value"><%= stats.updatedPages %></div>
      <div class="stat-label">SEO Updated</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card stat-card-blue">
      <div class="stat-icon stat-icon-blue">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
      </div>
      <div class="stat-value"><%= stats.totalMedia %></div>
      <div class="stat-label">Media Files</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="stat-card stat-card-purple">
      <div class="stat-icon stat-icon-purple">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      </div>
      <div class="stat-value"><%= stats.categories %></div>
      <div class="stat-label">Categories</div>
    </div>
  </div>
</div>

<!-- Quick actions -->
<div class="quick-actions-grid mb-4">
  <a href="/2ef65f179f12439e317a23628b016653/seo" class="quick-action-card quick-action-primary">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>SEO Manager</span>
  </a>
  <a href="/2ef65f179f12439e317a23628b016653/media" class="quick-action-card">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
    <span>Upload Media</span>
  </a>
  <a href="/2ef65f179f12439e317a23628b016653/redirects" class="quick-action-card">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15,10 20,15 15,20"/><path d="M4 4v7a4 4 0 004 4h12"/></svg>
    <span>Redirects</span>
  </a>
  <a href="/2ef65f179f12439e317a23628b016653/settings" class="quick-action-card">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
    <span>Settings</span>
  </a>
</div>

<div class="row g-3">
  <!-- Pages by category -->
  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header"><strong>Pages by Category</strong></div>
      <div class="card-body">
        <% if (categoryStats.length) { categoryStats.forEach(function(c) {
          var pct = stats.totalPages ? Math.round(c.count / stats.totalPages * 100) : 0;
        %>
        <div class="d-flex justify-content-between align-items-center mb-2" style="font-size:13px;">
          <span><%= c.name %></span>
          <span style="color:var(--text-3);font-weight:550;"><%= c.count %></span>
        </div>
        <div style="height:4px;background:var(--surface-2);border-radius:2px;margin-bottom:10px;">
          <div style="height:100%;width:<%= pct %>%;background:var(--gold);border-radius:2px;transition:width 0.5s;"></div>
        </div>
        <% }); } %>
      </div>
    </div>
  </div>

  <!-- Recent activity -->
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <strong>Recent Activity</strong>
        <a href="/2ef65f179f12439e317a23628b016653/activity" style="font-size:12px;font-weight:500;color:var(--gold);">View all →</a>
      </div>
      <div class="card-body" style="padding:8px 20px;">
        <% if (recentActivity.length) { %>
          <% recentActivity.forEach(function(a) { %>
          <div class="activity-item">
            <div>
              <span class="activity-user"><%= a.user %></span>
              <span class="activity-action"> — <%= a.action %></span>
              <% if (a.details) { %><span class="activity-details"> · <%= a.details %></span><% } %>
            </div>
            <span class="activity-time"><%= new Date(a.timestamp).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) %></span>
          </div>
          <% }); %>
        <% } else { %>
        <div class="empty-state" style="padding:30px;">
          <p>No activity recorded yet. Start by updating your SEO settings!</p>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('layout-end') %>
